#!/bin/zsh

set -eo pipefail

source "${DFH}/inc/helpers.zsh"

is_sourced() {
  [[ "${(%):-%N}" != "$0" ]]
}

safe_exit() {
  typeset -i code=${1:-0}

  if is_sourced; then
    return "$code"
  fi

  exit "$code"
}

show_help() {
  print "Usage: ./duti [-s|-i|-b]"
  print "  -s  Use VSCode Stable"
  print "  -i  Use VSCode Insiders"
  print "  -b  Use both VSCode Stable and Insiders"
}

if ! command -v duti >/dev/null 2>&1; then
  print -P "✘ %178Faborting%f Please \`brew install duti\` first"
  safe_exit 1
fi

# Detect installed VSCode variants
typeset -i has_stable=0
typeset -i has_insiders=0

if command -v code >/dev/null 2>&1 || [ -d "/Applications/Visual Studio Code.app" ]; then
  has_stable=1
fi

if command -v code-insiders >/dev/null 2>&1 || [ -d "/Applications/Visual Studio Code - Insiders.app" ]; then
  has_insiders=1
fi

# Check if at least one variant is installed
if [[ $has_stable -eq 0 && $has_insiders -eq 0 ]]; then
  abort "No VSCode variant detected. Please install VSCode or VSCode-Insiders first."
  show_help
  safe_exit 1
fi

# Parse optional non-interactive selection flags
typeset cli_choice=""
typeset -i selected_flags=0

while [[ "$#" -gt 0 ]]; do
  case "$1" in
    -s)
      cli_choice="s"
      (( selected_flags += 1 ))
      ;;
    -i)
      cli_choice="i"
      (( selected_flags += 1 ))
      ;;
    -b)
      cli_choice="b"
      (( selected_flags += 1 ))
      ;;
    -h|--help)
      show_help
      safe_exit 0
      ;;
    *)
      abort "Unknown option: $1"
      show_help
      safe_exit 1
      ;;
  esac
  shift
done

if (( selected_flags > 1 )); then
  abort "Please provide only one of -s, -i, or -b"
  show_help
  safe_exit 1
fi

# Build available options message
typeset available=""
if [[ $has_stable -eq 1 && $has_insiders -eq 1 ]]; then
  available="stable/insiders/both"
elif [[ $has_stable -eq 1 ]]; then
  available="stable only"
elif [[ $has_insiders -eq 1 ]]; then
  available="insiders only"
fi

# Prompt user for selection when no CLI flag is provided
typeset choice="$cli_choice"
if [[ -z "$choice" ]]; then
  question "Which VSCode variant to set as default?" "s/i/b"
  print -P "  Available: %39F${available}%f"
  read -rs -k 1 choice
  print -P "%39F> $choice%f"
else
  print -P "%39FUsing flag selection: $choice%f"
fi

typeset normalized_choice=${choice:l}

# Validate and confirm selection
typeset variant=""
case "$normalized_choice" in
  s)
    if [[ $has_stable -eq 0 ]]; then
      abort "VSCode stable is not installed"
      show_help
      safe_exit 1
    fi
    variant="stable"
    ;;
  i)
    if [[ $has_insiders -eq 0 ]]; then
      abort "VSCode-Insiders is not installed"
      show_help
      safe_exit 1
    fi
    variant="insiders"
    ;;
  b)
    if [[ $has_stable -eq 0 || $has_insiders -eq 0 ]]; then
      abort "Both variants are not installed"
      show_help
      safe_exit 1
    fi
    variant="both"
    ;;
  *)
    abort "Invalid selection. Please choose s, i, or b"
    show_help
    safe_exit 1
    ;;
esac

ok "Setting default file associations for VSCode ${variant}"

# Function to set file associations for a given bundle identifier
set_file_associations() {
  typeset bundle_id=$1
  typeset label=$2
  typeset -i failures=0

  print -P "\nℹ %178FConfiguring ${label}%f"

  # Some systems return -50 for unsupported/dynamic UTIs. Warn and continue.
  set_association() {
    typeset file_type=$1
    typeset -i cmd_status=0

    set +e
    formatexec "duti -s ${bundle_id} ${file_type} all"
    cmd_status=$?
    set -e

    if (( cmd_status != 0 )); then
      print -P "⚠ %178Fskipping unsupported association%f ${file_type}"
      (( failures += 1 ))
    fi
  }

  typeset -a utis=(
    public.json
    public.plain-text
    public.python-script
    public.shell-script
    public.source-code
    public.text
    public.unix-executable
  )

  typeset -a extensions=(
    .c
    .cfg
    .code-workspace
    .conf
    .cpp
    .cs
    .css
    .go
    .java
    .js
    .json
    .jsx
    .less
    .log
    .lua
    .md
    .php
    .pl
    .py
    .rb
    .sass
    .scss
    .sh
    .toml
    .ts
    .tsx
    .txt
    .vue
    .xml
    .yaml
    .yml
    .zsh
  )

  typeset -a file_types=("${utis[@]}" "${extensions[@]}")
  for file_type in "${file_types[@]}"; do
    set_association "$file_type"
  done

  if (( failures > 0 )); then
    print -P "⚠ %178F${label}: ${failures} association(s) were skipped%f"
  fi
}

# Execute based on user selection
case "$variant" in
  stable)
    set_file_associations "com.microsoft.VSCode" "VSCode Stable"
    ;;
  insiders)
    set_file_associations "com.microsoft.VSCodeInsiders" "VSCode Insiders"
    ;;
  both)
    set_file_associations "com.microsoft.VSCode" "VSCode Stable"
    set_file_associations "com.microsoft.VSCodeInsiders" "VSCode Insiders"
    ;;
esac

ok "File associations configured successfully"
